<?xml version="1.0" ?>
<robot name="panda">

  <link name="panda_link0">
    <collision name="panda_link0_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link0.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0172 0.0004 0.0745"/>
      <mass value="2.3966"/>
      <inertia ixx="0.009" ixy="0.0" ixz="0.002" iyy="0.0115" iyz="0.0" izz="0.0085"/>
    </inertial>
  </link>

  <link name="panda_link1">
    <collision name="panda_link1_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0 -0.0181 -0.0386"/>
      <mass value="2.9275"/>
      <inertia ixx="0.0239" ixy="0.0" ixz="0.0" iyy="0.0225" iyz="-0.002" izz="0.00635"/>
    </inertial>
  </link>

  <joint name="panda_joint1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.333"/>
    <parent link="panda_link0"/>
    <child link="panda_link1"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-2.7437" upper="2.7437" velocity="2.62"/>
  </joint>

  <link name="panda_link2">
    <collision name="panda_link2_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0032 -0.0743 0.0088"/>
      <mass value="2.9355"/>
      <inertia ixx="0.0419" ixy="0.0" ixz="0.004" iyy="0.0251" iyz="-0.0042" izz="0.0617"/>
    </inertial>
  </link>

  <joint name="panda_joint2" type="revolute">
    <origin rpy="-1.570796326794897 0 0" xyz="0 0 0"/>
    <parent link="panda_link1"/>
    <child link="panda_link2"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-1.7837" upper="1.7837" velocity="2.62"/>
  </joint>

  <link name="panda_link3">
    <collision name="panda_link3_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0407 -0.0048 -0.029"/>
      <mass value="2.2449"/>
      <inertia ixx="0.0241" ixy="0.0024" ixz="-0.0029" iyy="0.0197" iyz="-0.0021" izz="0.019"/>
    </inertial>
  </link>

  <joint name="panda_joint3" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0 -0.316 0"/>
    <parent link="panda_link2"/>
    <child link="panda_link3"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-2.9007" upper="2.9007" velocity="2.62"/>
  </joint>

  <link name="panda_link4">
    <collision name="panda_link4_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link4.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0459 0.063 -0.0085"/>
      <mass value="2.6156"/>
      <inertia ixx="0.0345" ixy="0.0132" ixz="0.0102" iyy="0.0289" iyz="-0.001" izz="0.0413"/>
    </inertial>
  </link>

  <joint name="panda_joint4" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0.0825 0 0"/>
    <parent link="panda_link3"/>
    <child link="panda_link4"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-3.0421" upper="-0.1518" velocity="2.62"/>
  </joint>

  <link name="panda_link5">
    <collision name="panda_link5_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link5.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0016 0.0293 -0.0973"/>
      <mass value="2.3271"/>
      <inertia ixx="0.0516" ixy="-0.0057" ixz="-0.0036" iyy="0.0479" iyz="0.0107" izz="0.0164"/>
    </inertial>
  </link>

  <joint name="panda_joint5" type="revolute">
    <origin rpy="-1.570796326794897 0 0" xyz="-0.0825 0.384 0"/>
    <parent link="panda_link4"/>
    <child link="panda_link5"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-2.8065" upper="2.8065" velocity="5.26"/>
  </joint>

  <link name="panda_link6">
    <collision name="panda_link6_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link6.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0597 -0.041 -0.0102"/>
      <mass value="1.817"/>
      <inertia ixx="0.0054" ixy="0.0062" ixz="0.0014" iyy="0.0141" iyz="-0.0013" izz="0.0161"/>
    </inertial>
  </link>

  <joint name="panda_joint6" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0 0 0"/>
    <parent link="panda_link5"/>
    <child link="panda_link6"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="0.5445" upper="4.5169" velocity="4.18"/>
  </joint>

  <!-- link7 now includes link8 + hand + finger meshes as one rigid body
       (Isaac Lab merges these via fixed joints; we bake them into one mesh) -->
  <link name="panda_link7">
    <collision name="panda_link7_collision">
      <geometry>
        <mesh filename="meshes/collision_arm/link7_with_hand.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0045 0.0086 0.04"/>
      <mass value="1.3815"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="panda_joint7" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0.088 0 0"/>
    <parent link="panda_link6"/>
    <child link="panda_link7"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-3.0159" upper="3.0159" velocity="5.26"/>
  </joint>

  <!-- Finger joints now parent to link7 directly.
       Origin = chain: T(0,0,0.107) * Rz(-pi/4) * T(0,0,0.0584)
       = T(0,0,0.1654) * Rz(-pi/4)   (since Rz doesn't affect Z translation)
       Both fingers share the SAME frame; they differ only in axis direction:
       left axis +Y, right axis -Y (matching the original Franka URDF). -->
  <link name="panda_leftfinger">
    <collision name="panda_leftfinger_collision">
      <geometry>
        <mesh filename="meshes/collision_hand/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.0146 0.0228"/>
      <mass value="0.05"/>
      <inertia ixx="3.01e-05" ixy="0.0" ixz="0.0" iyy="2.96e-05" iyz="0.0" izz="6.95e-06"/>
    </inertial>
  </link>

  <joint name="panda_finger_joint1" type="prismatic">
    <origin rpy="0 0 -0.7853981633974483" xyz="0 0 0.1654"/>
    <parent link="panda_link7"/>
    <child link="panda_leftfinger"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="0.0" upper="0.04" velocity="0.2"/>
  </joint>

  <link name="panda_rightfinger">
    <collision name="panda_rightfinger_collision">
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision_hand/finger.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 3.141592653589793" xyz="0 0.0146 0.0228"/>
      <mass value="0.05"/>
      <inertia ixx="3.01e-05" ixy="0.0" ixz="0.0" iyy="2.96e-05" iyz="0.0" izz="6.95e-06"/>
    </inertial>
  </link>

  <joint name="panda_finger_joint2" type="prismatic">
    <origin rpy="0 0 -0.7853981633974483" xyz="0 0 0.1654"/>
    <parent link="panda_link7"/>
    <child link="panda_rightfinger"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100" lower="0.0" upper="0.04" velocity="0.2"/>
  </joint>

</robot>
